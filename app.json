{
  "expo": {
    "name": "I-TRACK",
    "slug": "i-track-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "icon": "./public/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./public/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.itrack.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./public/logo-android-adaptive.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.itrack.mobile"
    },
    "web": {
      "favicon": "./public/icon-light-32x32.png"
    },
    "scheme": "itrack",
    "plugins": [
      "expo-router",
      "expo-notifications"
    ]
  }
}
